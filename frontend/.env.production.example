# Production build for embedding on a personal website (subpath).
# Copy to .env.production and adjust PUBLIC_PATH to match your site.

# URL path where the app is hosted (must start and end with /)
VITE_BASE_PATH=/tools/stochastic-volume/

# API prefix on the same host (Vercel rewrites /health and /api under this prefix)
VITE_API_BASE=/tools/stochastic-volume

# Optional: separate API host instead of VITE_API_BASE
# VITE_API_ORIGIN=https://api.yourdomain.com
